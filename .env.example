# Hetzner API token with permissions to manage servers and firewalls
HCLOUD_TOKEN=

# Hetzner location and server flavor (examples: fsn1, nbg1, hel1 / cx22, cpx21)
HCLOUD_LOCATION=
HCLOUD_SERVER_TYPE=
HCLOUD_IMAGE=ubuntu-24.04

# Server naming
SERVER_NAME=

# Public blog domain (must resolve to created server IP for trusted HTTPS cert issuance)
DOMAIN=

# Optional separate admin hostname; if empty, admin stays at https://DOMAIN/ghost/
ADMIN_DOMAIN=

# Optional Caddy ACME account email (recommended)
EMAIL_FOR_TLS=

# Pre-created Tailscale auth key for this node
TAILSCALE_AUTH_KEY=

# Your tailnet name for documentation and summary output (example: example.ts.net)
TAILSCALE_TAILNET=

# Linux admin user created on the server
SSH_ADMIN_USER=

# Ghost container tag
GHOST_VERSION=6-alpine

# MySQL credentials used by Ghost and MySQL container
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=

# Host timezone
TIMEZONE=UTC

# Optional host-side backup automation
ENABLE_BACKUPS=false
BACKUP_SCHEDULE=0 3 * * *

# Use Let's Encrypt staging endpoint while testing (recommended before first prod run)
LETSENCRYPT_STAGING=false
